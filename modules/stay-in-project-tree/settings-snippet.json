{
  "_comment": "Portable deny-list snippet for the stay-in-project-tree module. Paste these entries into the `permissions.deny` array of a host repo's .claude/settings.json. Replace `chriskornaros` with the actual username on the target host (or use `$HOME`-style anchoring if the host's settings.json supports it). The snippet covers system directories, credential stores, shell rc files, and the global Claude config; it intentionally does NOT block /tmp (some tools legitimately write there) or the per-project ~/.claude/projects/<hash>/ dir (Claude Code scopes that to this project by design). See the companion index.md for the prose rule.",
  "permissions": {
    "deny": [
      "Bash(cd /)",
      "Bash(cd /:*)",
      "Bash(cd /etc:*)",
      "Bash(cd /usr:*)",
      "Bash(cd /var:*)",
      "Bash(cd /opt:*)",
      "Bash(cd /System:*)",
      "Bash(cd /Library:*)",
      "Bash(cd /private:*)",
      "Bash(cd ~/.ssh:*)",

      "Read(/etc/**)",
      "Read(/private/etc/**)",
      "Read(/var/**)",
      "Read(/usr/**)",
      "Read(/System/**)",
      "Read(/Library/**)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/gh/**)",
      "Read(~/.gnupg/**)",

      "Edit(/etc/**)",
      "Edit(/private/etc/**)",
      "Edit(/var/**)",
      "Edit(/usr/**)",
      "Edit(/System/**)",
      "Edit(/Library/**)",
      "Edit(~/.ssh/**)",
      "Edit(~/.aws/**)",
      "Edit(~/.gitconfig)",
      "Edit(~/.zshrc)",
      "Edit(~/.bashrc)",
      "Edit(~/.bash_profile)",
      "Edit(~/.profile)",
      "Edit(~/.claude/settings.json)",
      "Edit(~/.claude/commands/**)",

      "Write(/etc/**)",
      "Write(/private/etc/**)",
      "Write(/var/**)",
      "Write(/usr/**)",
      "Write(/System/**)",
      "Write(/Library/**)",
      "Write(~/.ssh/**)",
      "Write(~/.aws/**)",
      "Write(~/.gitconfig)",
      "Write(~/.zshrc)",
      "Write(~/.bashrc)",
      "Write(~/.bash_profile)",
      "Write(~/.profile)",
      "Write(~/.claude/settings.json)",
      "Write(~/.claude/commands/**)",

      "Bash(crontab:*)",
      "Bash(launchctl:*)",
      "Bash(systemctl:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Bash(rsync:*)"
    ]
  }
}
